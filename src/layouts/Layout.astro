---
import "../styles/global.css";
import Header from '@/layouts/Header.astro';
import Footer from '@/layouts/Footer.astro';
import WhatsappButton from "@/components/WhatsappButton.astro";
import ProductThumbSpinnerInit from "@/components/product-thumb-spinner-init.astro";
import { ClientRouter } from "astro:transitions";
import faviconImportho from "@/assets/logo.webp";

---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href={faviconImportho.src} />
		<meta name="generator" content={Astro.generator} />
		<title>Importho</title>
		<ClientRouter />
	</head>
	<body class="flex flex-col min-h-screen">
		<Header />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />
		<WhatsappButton />
		<ProductThumbSpinnerInit />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100dvh;
		max-height: fit-content;
		display: flex;
		flex-direction: column;
		color: #484848;
	}
</style>
