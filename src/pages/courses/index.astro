---
import Layout from "@/layouts/Layout2.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Courses from "@/components/courses.astro";

const courses = await getCollection("courses");

---
<Layout>
  <article class="flex flex-col h-full w-10/12 mx-auto my-auto gap-8 mt-4 md:mt-auto md:gap-16 pb-24">
    <h1 class="text-4xl text-center font-bold text-primary">Cursos</h1>
    <p class="text-center text-zinc-600 max-w-3xl mx-auto">
      Encuentra los cursos disponibles y revisa nuestros cursos pasados.
    </p>
    <ul class="flex flex-col gap-4 w-full">
  {
    courses.map(({ data: { title, img, year, status }, slug }) => (
      <a href={slug}>
        <div class="relative">
          <Image
          src={img}
          alt={title}
          width={288}
          height={288}
          transition:name={`img-${slug}`}
          class="w-full h-auto" draggable="false"
          loading="lazy"
          decoding="async"
        />
          {status === "past" && year && (
            <span class="absolute top-3 left-3 bg-zinc-900/80 text-zinc-100 text-xs font-semibold px-3 py-1 rounded-full">
              Curso pasado {year}
            </span>
          )}
        </div>
      </a>
    ))
  }
</ul>
<Courses />
  </article>
</Layout>
