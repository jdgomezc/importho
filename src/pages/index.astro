---
import "../styles/global.css";
import Carousel from '@/components/Carousel.tsx';
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '@/assets/importho.webp';
import FeaturedProducts from '@/components/featured-products.astro';
import Courses from '@/components/courses.astro';
import { getCollection } from "astro:content";

const courses_collection = await getCollection("courses");

const courses = courses_collection.map(({ data: { title, img, status, year }, slug }) => ({
  title,
  slug: `/courses/${slug}`,
  img,
  status,
  year,
}));

---

<Layout>
	<section class="flex justify-center pb-24 md:pb-32 pt-8">
		<Image 
				src={logo} 
				alt="Importho Logo"
				class="w-10/12 md:w-[50rem] h-auto" 
				draggable="false"
				loading="eager"
				decoding="async"
			/>
	</section>

	<Carousel client:load courses={courses} />

	<FeaturedProducts />

	<Courses showPastBanner={false} />
</Layout>
