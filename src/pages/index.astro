---
import "../styles/global.css";
import Carousel from '@/components/Carousel.tsx';
import NewBrandPeclab from '@/components/new-brand-peclab.tsx';
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '@/assets/importho.webp';
import FeaturedProducts from '@/components/featured-products.astro';
import Courses from '@/components/courses.astro';
import { getCollection } from "astro:content";

const courses_collection = await getCollection("courses");

const statusOrder = { upcoming: 0, active: 1, past: 2 };

const courses = courses_collection
  .sort((a, b) => {
    const statusA = statusOrder[a.data.status ?? "active"] ?? 1;
    const statusB = statusOrder[b.data.status ?? "active"] ?? 1;
    if (statusA !== statusB) return statusA - statusB;
    return (b.data.year ?? 0) - (a.data.year ?? 0);
  })
  .map(({ data: { title, img, status, year, carouselBg }, slug }) => ({
    title,
    slug: `/courses/${slug}`,
    img,
    status,
    year,
    carouselBg,
  }));

const peclabProducts = (await getCollection("products"))
  .filter(({ data }) => data.brand === "Peclab")
  .slice(0, 6)
  .map(({ data: { title, img }, slug }) => ({
    title,
    slug,
    img,
  }));

---

<Layout>
	<section class="flex justify-center pb-20 pt-12 md:pb-32 md:pt-32">
		<Image 
				src={logo} 
				alt="Importho Logo"
				class="w-11/12 md:w-1/2 h-auto"
				draggable="false"
				loading="eager"
				decoding="async"
			/>
	</section>

	<NewBrandPeclab client:visible products={peclabProducts} />

	<Carousel client:load courses={courses} />

	<FeaturedProducts />

	<Courses showPastBanner={false} />
</Layout>
